{
  "name": "opswatch-unified",
  "version": "1.0.0",
  "description": "OpsWatch Unified Monitoring Dashboard - Aggregates service health, metrics, alerts, and incident tracking across Arivu microservices",
  "main": "server/src/index.js",
  "scripts": {
    "start": "node server/src/index.js",
    "seed": "node server/src/seed.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --detectOpenHandles",
