# OpsWatch Unified Monitoring Dashboard Configuration

# Server
PORT=3001
NODE_ENV=production

# JWT Secret - change this in production!
JWT_SECRET=opswatch-change-me-in-production-2024

# Database
DB_PATH=./data/opswatch.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Health Check
HEALTH_CHECK_TIMEOUT_MS=5000
